# Disposable test SOAR — runner exercises every operation against this.
# Copy to .env and fill in. Never commit .env.
FSR_BASE_URL=https://your-disposable-soar.example.com

# API key for `Authorization: API_KEY ...` testing
FSR_API_KEY=

# Username + password for JWT testing via POST /auth/authenticate
FSR_USERNAME=
FSR_PASSWORD=

# Optional: max seconds per request before marking timeout
FSR_TEST_TIMEOUT=15

# Optional: skip TLS verification (test SOARs often have self-signed certs)
FSR_VERIFY_TLS=false
