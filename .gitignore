# --- Generated specs & site artifacts ------------------------------------
# build/fortisoar.curated.openapi.yaml IS committed - it's the published
# spec for GitHub Pages. Rebuild it locally with src/build_curated.py +
# verify_curated.py and commit the new file when you want fresh examples.
build/fortisoar.openapi.yaml
build/public/
